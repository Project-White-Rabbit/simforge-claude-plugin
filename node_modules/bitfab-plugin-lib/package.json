{
  "name": "bitfab-plugin-lib",
  "version": "0.1.0",
  "private": true,
  "description": "Shared library for Bitfab editor plugins (Claude Code, Cursor, etc.)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prebuild": "node scripts/generate-baked-sdk-versions.mjs",
    "build": "tsc",
    "postbuild": "node scripts/build-skills.mjs",
    "predev": "node scripts/generate-baked-sdk-versions.mjs",
    "dev": "tsc --watch",
    "dev:flows": "vite --config dev-server/vite.config.ts",
    "snapshot:parent": "node dev-server/scripts/snapshot-parent.mjs",
    "test": "vitest run",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "tsc": "tsc --noEmit && tsc --noEmit -p dev-server/tsconfig.json",
    "knip": "knip",
    "madge": "madge --ts-config ./tsconfig.json --extensions ts --circular ./src && madge --extensions ts,tsx --circular ./dev-server/src",
    "build:skills": "pnpm build",
    "validate": "pnpm lint && pnpm tsc && pnpm knip && pnpm madge && pnpm build"
  },
  "author": "Bitfab",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "elkjs": "^0.11.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^20.0.0",
    "@types/react": "19.2.4",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "@xyflow/react": "^12.10.0",
    "react": "19.2.4",
    "react-diff-viewer-continued": "^4.2.2",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.15.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.0.0",
    "vite": "^7.2.4",
    "vitest": "^4.1.0"
  }
}
