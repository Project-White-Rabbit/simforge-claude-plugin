{
  "name": "bitfab-plugin-lib",
  "version": "0.1.0",
  "private": true,
  "description": "Shared library for Bitfab editor plugins (Claude Code, Cursor, etc.)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prebuild": "node scripts/generate-baked-sdk-versions.mjs",
    "build": "tsc",
    "predev": "node scripts/generate-baked-sdk-versions.mjs",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "tsc": "tsc --noEmit",
    "knip": "knip",
    "madge": "madge --ts-config ./tsconfig.json --extensions ts --circular ./src",
    "validate": "pnpm lint && pnpm tsc && pnpm knip && pnpm madge"
  },
  "author": "Bitfab",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  }
}
