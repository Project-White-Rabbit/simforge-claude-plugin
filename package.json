{
  "name": "bitfab-claude-plugin",
  "version": "0.1.52",
  "description": "Automated regression testing and improvements for your prompts, context, and tool calls.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "tsc": "tsc --noEmit",
    "knip": "knip",
    "madge": "madge --ts-config ./tsconfig.json --extensions ts --circular ./src",
    "validate": "pnpm lint && pnpm tsc && pnpm knip && pnpm madge"
  },
  "keywords": [
    "claude-code",
    "bitfab",
    "llm",
    "evaluation",
    "tracing",
    "mcp"
  ],
  "author": "Bitfab",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  }
}
